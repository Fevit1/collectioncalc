{
  "manifest_version": 3,
  "name": "Slab Guard Monitor",
  "version": "1.0.0",
  "description": "Monitor eBay listings for stolen comics registered with Slab Guard by SlabWorthy.com",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://slabworthy.com/*",
    "https://collectioncalc-docker.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/sch/*",
        "https://www.ebay.com/itm/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
