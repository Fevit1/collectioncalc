+<script>
+// Whatnot Prep Modal Logic
+let whatnotComic = null;
+
+async function openWhatnotPrepModal(comicId) {
+    whatnotComic = collection.find(c => c.id === comicId);
+    if (!whatnotComic) { alert('Comic not found'); return; }
+
