+        <div class="comic-preview-details">
+            <div class="comic-preview-title">${whatnotComic.title}</div>
+            <div class="comic-preview-meta">
+                #${whatnotComic.issue || '?'} • ${whatnotComic.publisher || 'Unknown'} • ${whatnotComic.year || '?'}
+            </div>
+            <span class="comic-preview-grade">${whatnotComic.grade || 'N/A'}</span>
+        </div>
+    `;
+
+    // Photos
+    const photosEl = document.getElementById('whatnotPhotos');
+    const photoSlots = [
+        { name: 'Front', url: whatnotComic.front_image },
+        { name: 'Spine', url: whatnotComic.spine_image },
+        { name: 'Back', url: whatnotComic.back_image },
+        { name: 'Center', url: whatnotComic.centerfold_image }
+    ];
+    photosEl.innerHTML = photoSlots.map(p => {
+        if (p.url) {
+            return `<div class="photo-download-item">
+                <img src="${p.url}" alt="${p.name}">
+                <a href="${p.url}" target="_blank" download>${p.name}</a>
+            </div>`;
+        }
+        return `<div class="photo-download-item no-photo">${p.name}: N/A</div>`;
+    }).join('');
+
+    // Generate content via API
+    await generateWhatnotContent();
+}
+
+function closeWhatnotModal() {
+    document.getElementById('whatnotModalOverlay').classList.remove('active');
+    whatnotComic = null;
+}
+
+async function generateWhatnotContent() {
+    const aiStatus = document.getElementById('whatnotAiStatus');
+    const aiText = document.getElementById('whatnotAiStatusText');
+    const token = localStorage.getItem('cc_token');
+
+    aiStatus.style.display = 'flex';
+    aiStatus.className = 'whatnot-ai-status generating';
+    aiText.textContent = 'Generating Whatnot content with AI...';
+
+    try {
+        const fmv = whatnotComic.slabbed_value || whatnotComic.raw_value || 9.99;
+
+        const response = await fetch(`${API_URL}/api/whatnot/generate-content`, {
+            method: 'POST',
+            headers: {
+                'Authorization': `Bearer ${token}`,
+                'Content-Type': 'application/json'
+            },
+            body: JSON.stringify({
+                title: whatnotComic.title,
+                issue: whatnotComic.issue,
+                grade: whatnotComic.grade,
+                price: fmv,
+                publisher: whatnotComic.publisher,
+                year: whatnotComic.year
+            })
+        });
+
+        const data = await response.json();
+
+        if (data.success) {
+            document.getElementById('whatnotTitle').value = data.listing_title || '';
+            document.getElementById('whatnotDescription').value = data.description || '';
+            document.getElementById('whatnotShowNotes').value = data.show_notes || '';
+            document.getElementById('whatnotStartPrice').textContent = `$${(data.suggested_start || 0.99).toFixed(2)}`;
+            document.getElementById('whatnotBuyNow').textContent = `$${(data.suggested_buy_now || fmv).toFixed(2)}`;
+
+            aiStatus.className = 'whatnot-ai-status success';
+            aiText.textContent = '✓ Content generated';
+            setTimeout(() => { aiStatus.style.display = 'none'; }, 3000);
+        } else {
+            throw new Error(data.error || 'Generation failed');
+        }
+    } catch (error) {
+        console.error('Whatnot content generation error:', error);
+        aiStatus.className = 'whatnot-ai-status error';
+        aiText.textContent = '✗ Failed — using template';
+
+        // Fallback
+        const fmv = whatnotComic.slabbed_value || whatnotComic.raw_value || 9.99;
+        document.getElementById('whatnotTitle').value = `${whatnotComic.title} #${whatnotComic.issue || '?'} ${whatnotComic.grade || ''}`.trim();
+        document.getElementById('whatnotDescription').value = `${whatnotComic.title} #${whatnotComic.issue || '?'} — a great pickup for any collection!`;
+        document.getElementById('whatnotShowNotes').value = `• ${whatnotComic.title} #${whatnotComic.issue || '?'}\n• ${whatnotComic.publisher || ''} ${whatnotComic.year || ''}\n• Graded ${whatnotComic.grade || 'N/A'} by Slab Worthy AI\n• FMV: $${fmv.toFixed(2)}\n• Low start — let the bidders decide!`;
+        document.getElementById('whatnotStartPrice').textContent = '$0.99';
+        document.getElementById('whatnotBuyNow').textContent = `$${fmv.toFixed(2)}`;
+    }
+}
+
+function copyWhatnotField(fieldId, btn) {
+    const field = document.getElementById(fieldId);
+    navigator.clipboard.writeText(field.value).then(() => {
+        btn.textContent = '✓';
+        btn.classList.add('copied');
+        setTimeout(() => {
+            btn.textContent = '📋';
+            btn.classList.remove('copied');
+        }, 2000);
+    }).catch(() => {
+        // Fallback for older browsers
+        field.select();
+        document.execCommand('copy');
+        btn.textContent = '✓';
+        btn.classList.add('copied');
+        setTimeout(() => {
+            btn.textContent = '📋';
+            btn.classList.remove('copied');
+        }, 2000);
+    });
+}
+
+function copyAllWhatnot(btn) {
+    const title = document.getElementById('whatnotTitle').value;
+    const desc = document.getElementById('whatnotDescription').value;
+    const notes = document.getElementById('whatnotShowNotes').value;
+    const start = document.getElementById('whatnotStartPrice').textContent;
+    const buyNow = document.getElementById('whatnotBuyNow').textContent;
+
+    const allText = `Title: ${title}\nStarting Bid: ${start}\nBuy Now: ${buyNow}\n\nDescription:\n${desc}\n\nShow Notes:\n${notes}`;
+
+    navigator.clipboard.writeText(allText).then(() => {
+        btn.textContent = '✓ Copied!';
+        btn.classList.add('copied');
+        setTimeout(() => {
+            btn.textContent = '📋 Copy All';
+            btn.classList.remove('copied');
+        }, 2500);
+    }).catch(() => {
+        // Fallback
+        const ta = document.createElement('textarea');
+        ta.value = allText;
+        document.body.appendChild(ta);
+        ta.select();
+        document.execCommand('copy');
+        document.body.removeChild(ta);
+        btn.textContent = '✓ Copied!';
+        btn.classList.add('copied');
+        setTimeout(() => {
+            btn.textContent = '📋 Copy All';
+            btn.classList.remove('copied');
+        }, 2500);
+    });
+}
+</script>
