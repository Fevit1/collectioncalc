+        // ── My Selling Platforms ────────────────────────────────
+        const SELL_PLATFORM_LIST = [
+            { key: 'ebay', name: 'eBay', color: '#e53238', type: 'Direct Listing', alwaysOn: true },
+            { key: 'whatnot', name: 'Whatnot', color: '#e67e22', type: 'Live Auction Prep' },
+            { key: 'mercari', name: 'Mercari', color: '#4dc0b5', type: 'Fixed Price Prep' },
+            { key: 'facebook', name: 'Facebook Marketplace', color: '#1877f2', type: 'Fixed Price Prep' },
+            { key: 'heritage', name: 'Heritage Auctions', color: '#1a3c6e', type: 'Consignment Prep' },
+            { key: 'comicconnect', name: 'ComicConnect', color: '#cc0000', type: 'Consignment Prep' },
+            { key: 'mycomicshop', name: 'MyComicShop', color: '#336699', type: 'Consignment Prep' },
+            { key: 'comc', name: 'COMC', color: '#e67e22', type: 'Consignment Prep' },
+            { key: 'hipcomic', name: 'Hip Comics', color: '#8b5cf6', type: 'Consignment Prep' }
+        ];
+
+        function getSellPlatformPrefs() {
+            try { return JSON.parse(localStorage.getItem('sw_sell_platforms') || '{}'); }
+            catch (e) { localStorage.removeItem('sw_sell_platforms'); return {}; }
+        }
+
+        function loadPlatformPrefs() {
+            const saved = getSellPlatformPrefs();
+            const container = document.getElementById('platformToggles');
+            container.innerHTML = SELL_PLATFORM_LIST.map(p => {
+                const isOn = p.alwaysOn || saved[p.key] === true;
+                return `<div class="platform-toggle-row">
+                    <div class="platform-toggle-info">
+                        <div class="platform-toggle-dot" style="background:${p.color}"></div>
+                        <span class="platform-toggle-name">${p.name}</span>
+                        <span class="platform-toggle-type">${p.type}</span>
+                    </div>
+                    <label class="platform-toggle">
+                        <input type="checkbox" ${isOn ? 'checked' : ''} ${p.alwaysOn ? 'disabled' : ''}
+                               onchange="savePlatformPref('${p.key}', this.checked)">
+                        <span class="slider"></span>
+                    </label>
+                </div>`;
+            }).join('');
+        }
+
+        function savePlatformPref(key, enabled) {
+            const saved = JSON.parse(localStorage.getItem('sw_sell_platforms') || '{}');
+            saved[key] = enabled;
+            localStorage.setItem('sw_sell_platforms', JSON.stringify(saved));
+        }
+
         // Load
         loadAccount();
         loadSightings();
         loadEbayStatus();
+        loadPlatformPrefs();
     </script>
